{
    "editor.formatOnSave": true,
    "code-runner.executorMap": {
        "c": "make run input=src/$fileName",
        "cpp": "make run input=src/$fileName",
        "java": "javac src/structs/*.java; java -cp src src/$fileName",
        "javascript": "node",
        "typescript": "deno run",
        "python": "source .venv/bin/activate; python"
    },
    "code-runner.runInTerminal": true,
    "go.toolsEnvVars": {
        "CGO_ENABLED": 0
    },
    "python.pythonPath": ".venv/bin/python",
    "python.formatting.provider": "yapf",
    "clang-tidy.fixOnSave": true,
    "clang-tidy.compilerArgs": ["-std=c++17"]
}
